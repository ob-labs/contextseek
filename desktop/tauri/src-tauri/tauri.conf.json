{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ContextSeek",
  "version": "0.2.0",
  "identifier": "ai.oceanbase.contextseek",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ContextSeek",
        "width": 1200,
        "height": 800,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "visible": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:*; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' http://127.0.0.1:*; font-src 'self' data:; frame-ancestors 'none';",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "dmg", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/contextseek-desktop-server"],
    "resources": { "../../../dashboard/dist": "dashboard-dist" },
    "category": "Productivity",
    "shortDescription": "Local context memory for agents",
    "longDescription": "ContextSeek desktop app — same-origin dashboard backed by a local Python sidecar."
  },
  "plugins": {}
}
