{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capability: run the bundled Python sidecar. Window/tray/navigation are driven from Rust, so no JS-facing window/webview permissions are needed.",
  "remote": {
    "urls": ["http://127.0.0.1:*"]
  },
  "windows": ["main"],
  "permissions": [
    "core:default",
    "autostart:default",
    "dialog:default",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/contextseek-desktop-server",
          "sidecar": true,
          "args": [
            "--host",
            "127.0.0.1",
            "--port",
            { "validator": "\\d+" }
          ]
        }
      ]
    }
  ]
}
